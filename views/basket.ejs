<%- include("partials/header") %>

<h1>Your Basket</h1>

<% if(basket.length === 0){ %>

<h2>Your basket is empty.</h2>

<% } else { %>

<table class="basket-table">

    <tr>
        <th>Product</th>
        <th>Quantity</th>
        <th>Price</th>
        <th>Subtotal</th>
        <th></th>
    </tr>

<% basket.forEach(item => { %>

<tr>

<td>

<img src="<%= item.product.image %>" width="100">

<br>

<strong><%= item.product.name %></strong>

</td>

<td>

<form action="/basket/decrease/<%= item.product.id %>" method="POST" style="display:inline">
<button>-</button>
</form>

<strong><%= item.quantity %></strong>

<form action="/basket/increase/<%= item.product.id %>" method="POST" style="display:inline">
<button>+</button>
</form>

</td>

<td>

£<%= item.product.price.toFixed(2) %>

</td>

<td>

£<%= (item.product.price * item.quantity).toFixed(2) %>

</td>

<td>

<form action="/basket/remove/<%= item.product.id %>" method="POST">

<button>Remove</button>

</form>

</td>

</tr>

<% }) %>

</table>

<div class="summary">

<h2>Order Summary</h2>

<p>Subtotal: £<%= subtotal.toFixed(2) %></p>

<p>Shipping: £<%= shipping.toFixed(2) %></p>

<p>VAT (20%): £<%= vat.toFixed(2) %></p>

<hr>

<h2>Total: £<%= total.toFixed(2) %></h2>

<button>Proceed to Checkout</button>

</div>

<% } %>

<%- include("partials/footer") %>